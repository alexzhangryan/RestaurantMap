02526810772/reviews", "photoUri": "https://lh3.googleusercontent.com/a-/ALV-UjUHH3SCooRhMyDvvvdgkHKCoH3N1tXlNkQIMnE9eA8TQKuN8_I-=s128-c0x00000000-cc-rp-mo-ba5"}, "publishTime": "2025-12-09T04:54:47.728906424Z", "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT210ZmRsUTBibE5hTmxwT2IyNVpVMWhXU1hKbWFIYxAB&d=17924085&t=1", "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT210ZmRsUTBibE5hTmxwT2IyNVpVMWhXU1hKbWFIYxAB!2m1!1s0x80857f001f9c84e7:0xa069d30803274ccc"}, {"name": "places/ChIJ54ScHwB_hYARzEwnAwjTaaA/reviews/Ci9DQUlRQUNvZENodHljRjlvT2pSYVlsSlNVWFJSZVZCQkxXeHlkR3R1UW5SMWJYYxAB", "relativePublishTimeDescription": "5 months ago", "rating": 4, "text": {"text": "I’m a big fan of Shaanxi-style food, and the biangbiang noodles at this place did not disappoint. The noodles are very fresh and well-cooked, with just the right amount of chewiness. The chili oil and garlic was fragrant and delicious as well. My one gripe with the dish, however, is that the noodles are cut much thinner than what is typical for biangbiang noodles. Had the noodles been cut into thicker pieces, this dish would have been all the more tasty. That said, I would definitely recommend this place — the noodles are legit for sure", "languageCode": "en"}, "originalText": {"text": "I’m a big fan of Shaanxi-style food, and the biangbiang noodles at this place did not disappoint. The noodles are very fresh and well-cooked, with just the right amount of chewiness. The chili oil and garlic was fragrant and delicious as well. My one gripe with the dish, however, is that the noodles are cut much thinner than what is typical for biangbiang noodles. Had the noodles been cut into thicker pieces, this dish would have been all the more tasty. That said, I would definitely recommend this place — the noodles are legit for sure", "languageCode": "en"}, "authorAttribution": {"displayName": "Sam Mills", "uri": "https://www.google.com/maps/contrib/115868031201332813181/reviews", "photoUri": "https://lh3.googleusercontent.com/a/ACg8ocJVM2dE-VhF8nkJzKTshwEh9LVh95iWJP9pRxVRB8OzTo_50g=s128-c0x00000000-cc-rp-mo"}, "publishTime": "2026-02-04T23:14:51.063669589Z", "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT2pSYVlsSlNVWFJSZVZCQkxXeHlkR3R1UW5SMWJYYxAB&d=17924085&t=1", "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2pSYVlsSlNVWFJSZVZCQkxXeHlkR3R1UW5SMWJYYxAB!2m1!1s0x80857f001f9c84e7:0xa069d30803274ccc"}, {"name": "places/ChIJ54ScHwB_hYARzEwnAwjTaaA/reviews/Ci9DQUlRQUNvZENodHljRjlvT2pScU1USXdiVmM0WVZBdFJ6SlVkalpKVFcxd05sRRAB", "relativePublishTimeDescription": "2 months ago", "rating": 5, "text": {"text": "Delicious noodle, could get noodle refill, feed me well.", "languageCode": "en"}, "originalText": {"text": "Delicious noodle, could get noodle refill, feed me well.", "languageCode": "en"}, "authorAttribution": {"displayName": "De Dong", "uri": "https://www.google.com/maps/contrib/114258338822658507935/reviews", "photoUri": "https://lh3.googleusercontent.com/a-/ALV-UjWoahWicAoABnjRaVGJ2LcH_ZBobOhAUnmL48yCd6Z2gc-vGX4=s128-c0x00000000-cc-rp-mo"}, "publishTime": "2026-05-14T01:14:20.803136248Z", "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT2pScU1USXdiVmM0WVZBdFJ6SlVkalpKVFcxd05sRRAB&d=17924085&t=1", "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2pScU1USXdiVmM0WVZBdFJ6SlVkalpKVFcxd05sRRAB!2m1!1s0x80857f001f9c84e7:0xa069d30803274ccc"}, {"name": "places/ChIJ54ScHwB_hYARzEwnAwjTaaA/reviews/Ci9DQUlRQUNvZENodHljRjlvT2kxbGJHaElRVGhPY0dWWGR6TlFaV0U1WmtoQk9WRRAB", "relativePublishTimeDescription": "4 months ago", "rating": 2, "text": {"text": "The noodle is Okie,  chewy but other than that nothing special. The broth tastes artificial and watered down. Meat in noodle is way too fatty. The worst is the lamb skewers, had to spit out after chewing it for a minute.", "languageCode": "en"}, "originalText": {"text": "The noodle is Okie,  chewy but other than that nothing special. The broth tastes artificial and watered down. Meat in noodle is way too fatty. The worst is the lamb skewers, had to spit out after chewing it for a minute.", "languageCode": "en"}, "authorAttribution": {"displayName": "Jessica", "uri": "https://www.google.com/maps/contrib/107978338833489853464/reviews", "photoUri": "https://lh3.googleusercontent.com/a/ACg8ocJlyfC_kFzqfmqMwwHELvCHmtjd5gz25azLX4gEuhVuSI5bpA=s128-c0x00000000-cc-rp-mo"}, "publishTime": "2026-02-14T21:29:11.675790439Z", "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT2kxbGJHaElRVGhPY0dWWGR6TlFaV0U1WmtoQk9WRRAB&d=17924085&t=1", "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2kxbGJHaElRVGhPY0dWWGR6TlFaV0U1WmtoQk9WRRAB!2m1!1s0x80857f001f9c84e7:0xa069d30803274ccc"}], "photos": [{"name": "places/ChIJ54ScHwB_hYARzEwnAwjTaaA/photos/AWCwydjySupCLmTl25lX7VzFAKrdGE0c9XAHfB-1UjnwXnHJGECcbODCPx-9b8NuKhBfcOHirPBat-8s3w9GHPTh7yH2tfX2BIqPmA5tbaEzIb4FVQA1_pPiIvHMGZjP16hvDiAnblPB-B7Iyl_wmiNdvwfcHLd5fLVlq5X0C62Mlu2G8HmuRTF0TeJqSForZLqi0Au3hna-hebfwK-VlPQymOZO9xzj7ybuP35UOo_e7X0nVOotBId1czAdfhk0xYLvNo5XsQLerGGE2Hmpxuu9RXbfLa0_69ArwwzcdRQgCcSMR1ezlBFCmd7B0JDYikezqnc50AtxJiAb2IpO6ElrzR8sIw-KyCrz18HnsEJruWOiZdwkWknZWHuxVTjxTVxQc50ocZT3kWUeSH_YyrBgAnlgSDwvp3DvENWH-JNLyOrrie-vvVFDtjrg3tuSddX3", "widthPx": 4000, "heightPx": 3000, "authorAttributions": [{"displayName": "Jeronimo Mora", "uri": "https://maps.google.com/maps/contrib/102823999502526810772", "photoUri": "https://lh3.googleusercontent.com/a-/ALV-UjUHH3SCooRhMyDvvvdgkHKCoH3N1tXlNkQIMnE9eA8TQKuN8_I-=s100-p-k-no-mo"}], "flagContentUri": "https://www.google.com/local/content/rap/report?postId=!1e10!2sCIABIhDanY8w6a2CE_pHnZ25p_Bj&t=27&cb_client=maps_api_places.places_api&hl=e