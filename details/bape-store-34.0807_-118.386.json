ode": "en"}, "authorAttribution": {"displayName": "marcus johnson", "uri": "https://www.google.com/maps/contrib/113756851132096931579/reviews", "photoUri": "https://lh3.googleusercontent.com/a-/ALV-UjXKoZz5cl4Ov0NJfXlxqrk7nm3j5n_cQm3grlP9ROJ2Swa-C7g=s128-c0x00000000-cc-rp-mo"}, "publishTime": "2026-04-30T22:47:22.352643895Z", "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT2tOVk5HMDVhSFJPVWtaM01qbHhUV042VkZsU09VRRAB&d=17924085&t=1", "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2tOVk5HMDVhSFJPVWtaM01qbHhUV042VkZsU09VRRAB!2m1!1s0x80c2beaedc0c0001:0x341e73606115f339"}, {"name": "places/ChIJAQAM3K6-woAROfMVYWBzHjQ/reviews/Ci9DQUlRQUNvZENodHljRjlvT20xa2NrdGlieTFUUW5CMlMydEpNVVJNVFZKdVluYxAB", "relativePublishTimeDescription": "6 months ago", "rating": 5, "text": {"text": "The team here is so nice!!! The store manager, Davon, really went above and beyond to help me find my boyfriend a gift for the holidays. He took all of the stress out of it. I will definitely be back!", "languageCode": "en"}, "originalText": {"text": "The team here is so nice!!! The store manager, Davon, really went above and beyond to help me find my boyfriend a gift for the holidays. He took all of the stress out of it. I will definitely be back!", "languageCode": "en"}, "authorAttribution": {"displayName": "Brittany Butler", "uri": "https://www.google.com/maps/contrib/105519378961611394806/reviews", "photoUri": "https://lh3.googleusercontent.com/a-/ALV-UjXtO4VccDG0-vKq4eg2msAAPuYXBnF9F-9Uy_-1LfPd3sUWrZhY=s128-c0x00000000-cc-rp-mo"}, "publishTime": "2025-12-26T16:17:17.762818491Z", "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT20xa2NrdGlieTFUUW5CMlMydEpNVVJNVFZKdVluYxAB&d=17924085&t=1", "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT20xa2NrdGlieTFUUW5CMlMydEpNVVJNVFZKdVluYxAB!2m1!1s0x8